# Bluesky bot account (create dedicated account, NOT your personal one)
BSKY_HANDLE=your-bot.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Memelord image generation API
MEMELORD_API_KEY=

# Railway-provisioned Redis (auto-injected on Railway, set manually for local dev)
REDIS_URL=redis://localhost:6379

# Railway-provisioned Postgres (auto-injected on Railway, set manually for local dev)
DATABASE_URL=postgresql://user:password@localhost:5432/social_media_agent

# Mem0 for qualitative agent memory
MEM0_API_KEY=

# Google Gemini (Flash) for sentiment analysis and safety review
GEMINI_API_KEY=

# Apify for setup-time reference meme scraping (one-time use only, see §9 of spec)
APIFY_API_KEY=

# Niche config — change this one line to pivot niche (see §1 of spec)
NICHE=software-engineering
