{
  "name": "social-media-agent",
  "version": "0.1.0",
  "description": "Autonomous Bluesky meme agent — Kiloforge take-home",
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@atproto/api": "^0.14.0",
    "@google/genai": "^2.9.0",
    "drizzle-orm": "^0.38.0",
    "mem0ai": "^3.0.9",
    "postgres": "^3.4.5",
    "redis": "^4.7.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
